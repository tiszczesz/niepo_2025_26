@model List<User>
<h3>
    Lista użytkowników
</h3>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Lp</th>
            <th>Nazwa użytkownika</th>
            <th>Email</th>
            <th>Data utworzenia</th>
            <th> ----  </th>
        </tr>
    </thead>
    <tbody>
        @foreach(User u in Model){
            <tr>
                <td>@u.Id</td>
                <td>@u.Username</td>
                <td>@u.Email</td>
                <td>@u.Date?.ToString("dd-MM-yyyy")</td>
                <td>
                    <a asp-route-id="@u.Id" asp-action="Delete" 
                    class="btn btn-outline-danger">Usuń</a>
                    <a asp-route-id="@u.Id" asp-action="Update" 
                    class="btn btn-outline-secondary">Edytuj</a>
                </td>
                    
            </tr>
        }
    </tbody>
</table>